# --- Core retrieval storage ---
# Required for the Agno/live smoke path.
RAG_QDRANT_URL=http://127.0.0.1:6333
RAG_QDRANT_COLLECTION=documents_live_hybrid_smoke

# Default dense+sparse runtime path (FastEmbed).
# Keep RAG_DENSE_MODEL set unless you intentionally switch to HTTP embeddings.
RAG_DENSE_MODEL=BAAI/bge-small-en-v1.5
RAG_SPARSE_MODEL=Qdrant/bm25

# --- Agent model wiring ---
# Example values: openai:gpt-5-mini, openai:gpt-4.1-mini
AGNO_MODEL=openai:gpt-5-mini

# Leave blank in repo. Set only in your local shell/.env/secret store when needed.
OPENAI_API_KEY=

# --- Optional embedding backend override ---
# Valid values: fastembed | openai_compatible
# Default behavior is FastEmbed + local sparse encoder.
RAG_EMBEDDING_PROVIDER=fastembed

# Used only when RAG_EMBEDDING_PROVIDER=openai_compatible.
# Expected API shape: POST /v1/embeddings with {model, input:[...]}.
RAG_EMBEDDING_BASE_URL=http://127.0.0.1:8000
RAG_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# Explicit HTTP timeout for embedding requests.
RAG_EMBEDDING_TIMEOUT_SECONDS=10

# --- Optional reranker backend override ---
# Valid values: none | http_qwen
# If unset/none, retrieval falls back to the current lightweight rerank behavior.
# If http_qwen construction fails at startup, wiring also falls back to lightweight rerank.
RAG_RERANKER_PROVIDER=none
RAG_RERANKER_BASE_URL=http://127.0.0.1:8090
RAG_RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
# Explicit HTTP timeout for reranker requests.
RAG_RERANKER_TIMEOUT_SECONDS=10

# --- Optional FastEmbed tuning ---
# Leave blank to use library defaults.
RAG_FASTEMBED_CACHE_DIR=
RAG_FASTEMBED_THREADS=
